#!/usr/bin/env python3
import os
import sys
import threading
import time
from datetime import datetime

from rich.console import Console
from rich.markdown import Markdown
from rich.panel import Panel
from rich.table import Table

from prompt_toolkit import Application
from prompt_toolkit.key_binding import KeyBindings
from prompt_toolkit.layout import Layout, HSplit, Window, BufferControl
from prompt_toolkit.buffer import Buffer
from prompt_toolkit.widgets import TextArea, Label
from prompt_toolkit.shortcuts import PromptSession, confirm
from prompt_toolkit.formatted_text import HTML

# --- CONFIGURATION ---
NOTES_DIR = os.path.expanduser("~/md_notes")
console = Console()

def setup_env():
    if not os.path.exists(NOTES_DIR):
        os.makedirs(NOTES_DIR)

class MDNotesEditor:
    def __init__(self, filepath, title):
        self.filepath = filepath
        self.title = title
        self.text_area = TextArea(
            text=self._load_content(),
            multiline=True,
            scrollbar=True,
            line_numbers=True,
        )
        self.last_saved_content = self.text_area.text
        self.kb = KeyBindings()
        self.setup_bindings()
        
        # Auto-save thread
        self.stop_autosave = threading.Event()
        self.autosave_thread = threading.Thread(target=self.autosave_loop, daemon=True)
        self.autosave_thread.start()

    def _load_content(self):
        if os.path.exists(self.filepath):
            with open(self.filepath, "r") as f:
                return f.read()
        return f"# {self.title}\n\n"

    def save(self):
        content = self.text_area.text
        with open(self.filepath, "w") as f:
            f.write(content)
        self.last_saved_content = content
        return "Saved!"

    def autosave_loop(self):
        while not self.stop_autosave.is_set():
            time.sleep(120)  # 2 minutes
            if not self.stop_autosave.is_set():
                if self.text_area.text != self.last_saved_content:
                    self.save()

    def setup_bindings(self):
        @self.kb.add("escape", "s") # Alt+S
        def _(event):
            self.save()
            event.app.invalidate()

        @self.kb.add("escape", "z") # Alt+Z
        def _(event):
            self.text_area.buffer.undo()

        @self.kb.add("escape", "n") # Alt+N
        def _(event):
            # Signal to the home loop that we want a new note
            self.save()
            self.stop_autosave.set()
            event.app.exit(result="cmd_new_note")

        @self.kb.add("escape", "enter") # Save & Exit
        def _(event):
            self.save()
            self.stop_autosave.set()
            event.app.exit(result="cmd_exit_to_menu")

    def run(self):
        help_text = HTML(
            '<style bg="ansiyellow" fg="ansiblack"> Alt+S: Save </style> '
            '<style bg="ansigreen" fg="ansiblack"> Alt+N: New Note </style> '
            '<style bg="ansiblue" fg="ansiwhite"> Alt+Z: Undo </style> '
            '<style bg="ansired" fg="ansiwhite"> Esc+Enter: Save &amp; Back </style>'
        )

        format_info = (
            "# H1 | ## H2 | **Bold** | *Italic* | - List | 1. List | `Code` | > Quote"
        )

        layout = HSplit([
            Label(f" Editing: {self.title} ", style="bold bg:ansiwhite fg:ansiblack"),
            self.text_area,
            Label(format_info, style="bg:ansidarkgray fg:ansiwhite"),
            Window(content=BufferControl(buffer=Buffer(document=help_text, read_only=True)), height=1),
        ])

        app = Application(layout=Layout(layout), key_bindings=self.kb, full_screen=True)
        result = app.run()
        self.stop_autosave.set()
        return result

def list_and_select():
    setup_env()
    files = sorted([f for f in os.listdir(NOTES_DIR) if f.endswith(".md")], reverse=True)
    if not files:
        return None

    console.print("\n[bold]Existing Notes:[/bold]")
    for i, f in enumerate(files, 1):
        console.print(f"[{i}] {f}")
    
    try:
        choice = input("\nSelect note # (or 0 to cancel): ")
        idx = int(choice)
        if 0 < idx <= len(files):
            return files[idx-1]
    except:
        pass
    return None

def open_editor(path, title):
    editor = MDNotesEditor(path, title)
    result = editor.run()
    
    if result == "cmd_new_note":
        # Handle the Alt+N flow
        if confirm("Save current and start a new note? (y/n)"):
            new_title = input("New Note Title: ").strip()
            if new_title:
                new_filename = new_title.replace(" ", "_") + ".md"
                new_path = os.path.join(NOTES_DIR, new_filename)
                open_editor(new_path, new_title) # Recursive call to restart editor
    # Otherwise, it returns to the interactive_home loop

def interactive_home():
    setup_env()
    while True:
        console.clear()
        console.print(Panel.fit("[bold green]Welcome to mdnotes[/bold green]\n[dim]Simple Markdown for the CLI[/dim]", border_style="green"))
        
        console.print("\n[1] Create [bold]New Note[/bold]")
        console.print("[2] Open [bold]Existing Note[/bold]")
        console.print("[3] Search")
        console.print("[0] Exit to Bash")
        
        choice = input("\nAction: ")
        
        if choice == "1":
            title = input("Note Title: ").strip()
            if title:
                filename = title.replace(" ", "_") + ".md"
                path = os.path.join(NOTES_DIR, filename)
                open_editor(path, title)
        elif choice == "2":
            fname = list_and_select()
            if fname:
                path = os.path.join(NOTES_DIR, fname)
                open_editor(path, fname.replace(".md", ""))
        elif choice == "3":
            query = input("Search term: ")
            found = False
            for f in os.listdir(NOTES_DIR):
                if f.endswith(".md"):
                    with open(os.path.join(NOTES_DIR, f), "r") as file:
                        if query.lower() in file.read().lower():
                            console.print(f"[green]Found in:[/green] {f}")
                            found = True
            if not found: console.print("No matches.")
            input("Press Enter to continue...")
        elif choice == "0":
            break

if __name__ == "__main__":
    interactive_home()
